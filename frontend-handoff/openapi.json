{
  "openapi": "3.1.0",
  "info": {
    "title": "TraceAI Enterprise Control Plane",
    "version": "1.1.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "developer", "viewer"] },
          "created_at": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "refresh_token": { "type": "string" },
          "token_type": { "type": "string", "enum": ["bearer"] },
          "expires_in": { "type": "integer" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "RunSubmitRequest": {
        "type": "object",
        "required": ["session_id", "goal"],
        "properties": {
          "session_id": { "type": "string" },
          "goal": { "type": "string" },
          "agent_id": { "type": "string", "nullable": true }
        }
      },
      "RunStatus": {
        "type": "object",
        "properties": {
          "run_id": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "running", "completed", "failed"] },
          "goal": { "type": "string", "nullable": true },
          "agent_id": { "type": "string", "nullable": true },
          "agent_name": { "type": "string", "nullable": true },
          "started_at": { "type": "string", "format": "date-time", "nullable": true },
          "completed_at": { "type": "string", "format": "date-time", "nullable": true },
          "cache_hit": { "type": "boolean" },
          "latency_total": { "type": "number", "nullable": true },
          "error": { "type": "string", "nullable": true },
          "result": { "type": "string", "nullable": true }
        }
      },
      "AgentRequest": {
        "type": "object",
        "required": ["session_id", "goal"],
        "properties": {
          "session_id": { "type": "string" },
          "goal": { "type": "string" },
          "agent_id": { "type": "string", "nullable": true }
        }
      },
      "AgentResponse": {
        "type": "object",
        "properties": {
          "result": { "type": "string" },
          "request_id": { "type": "string", "nullable": true },
          "status": { "type": "string", "enum": ["queued", "running", "completed", "failed"], "nullable": true }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "responses": { "200": { "description": "Lightweight health response" } }
      }
    },
    "/ready": {
      "get": {
        "summary": "Readiness",
        "responses": { "200": { "description": "Dependencies ready" }, "503": { "description": "Degraded dependencies" } }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthRequest" } } } },
        "responses": { "200": { "description": "Token response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } } } }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthRequest" } } } },
        "responses": { "200": { "description": "Token response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } } } }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Refresh token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": { "refresh_token": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Token response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TokenResponse" } } } } }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Current user",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Authenticated user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } } }
      }
    },
    "/agent/run": {
      "post": {
        "summary": "Run agent synchronously",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentRequest" } } } },
        "responses": { "200": { "description": "Agent response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentResponse" } } } } }
      }
    },
    "/api/runs/submit": {
      "post": {
        "summary": "Submit queued run",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RunSubmitRequest" } } } },
        "responses": {
          "202": {
            "description": "Queued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "run_id": { "type": "string" },
                    "status": { "type": "string", "enum": ["queued"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}/status": {
      "get": {
        "summary": "Run status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "run_id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Run status", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RunStatus" } } } } }
      }
    },
    "/traces/{request_id}": {
      "get": {
        "summary": "Get canonical trace",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "request_id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Trace document" } }
      }
    },
    "/api/eval/run-suite": {
      "post": {
        "summary": "Run whitelisted eval suite",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["suite_name"],
                "properties": { "suite_name": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Eval suite result" } }
      }
    }
  }
}
